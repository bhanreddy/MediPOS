{
  "expo": {
    "name": "MedPOS",
    "slug": "medical-pos-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "scheme": "medical-pos",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0066CC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.medpos.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Biometric login for secure access"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0066CC"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.medpos.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera access is needed for barcode scanning and bill capture."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Biometric authentication for secure login."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow MedPOS to access photos for bill scanning."
        }
      ]
    ]
  }
}
