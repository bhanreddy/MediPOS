PORT=5000
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Include ClinicPOSOfflineFirst Vite dev port (5174) when testing offline sync UI
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8081
NODE_ENV=development

# SuperAdmin app calls /api/v1/medical/* on this server. Tokens are issued by the school Supabase project;
# validate them with the school (ops) project keys — never reuse Medical POS service role for this.
SCHOOL_OPS_SUPABASE_URL=
SCHOOL_OPS_SUPABASE_ANON_KEY=
SCHOOL_OPS_SUPABASE_SERVICE_ROLE_KEY=
